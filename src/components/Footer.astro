---
import { Image } from 'astro:assets';
import Logo from '@assets/images/white-logo.svg';
import Button from '@components/ui/Button.astro';

const companyLinks = [
  { label: 'About', href: '#' },
  { label: 'Our Process', href: '#' },
  { label: 'Join our team', href: '#' },
];

const resourceLinks = [
  { label: 'News', href: '#' },
  { label: 'Research', href: '#' },
  { label: 'Recent Projects', href: '#' },
];
---

<footer
  class='footer-container bg-zinc-950 pt-20 pb-10 text-zinc-50'
  aria-labelledby='footer-heading'
>
  <h2 id='footer-heading' class='sr-only'>Footer</h2>

  <div class='mx-auto max-w-7xl px-6'>
    <div class='mb-16 grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8'>
      <!-- logo -->
      <div class='footer-brand space-y-8 opacity-0 lg:col-span-5'>
        <a
          href='#'
          class='inline-flex items-center gap-2 transition-transform duration-300 outline-none select-none hover:scale-105'
          draggable='false'
        >
          <Image
            src={Logo}
            alt='Brand Logo'
            loading='eager'
            draggable='false'
          />
        </a>

        <!-- newsletter -->
        <div class='max-w-md space-y-4 rounded-2xl bg-zinc-50 p-6 md:p-8'>
          <h3 class='text-lg font-medium text-zinc-700 md:text-xl'>
            Subscribe to newsletter
          </h3>
          <p class='text-sm leading-relaxed text-zinc-900'>
            Subscribe now to receive tips on how to take your business to the
            next level.
          </p>

          <form class='flex flex-col gap-3 pt-2 sm:flex-row'>
            <label for='email-address' class='sr-only'>Email address</label>
            <input
              id='email-address'
              name='email'
              type='email'
              autocomplete='email'
              required
              class='flex-1 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm text-zinc-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none'
              placeholder='Enter your email'
            />
            <Button variant='primary' size='md' class='shrink-0'>
              Subscribe
            </Button>
          </form>
        </div>
      </div>

      <!-- nav links -->
      <div
        class='footer-nav flex flex-col justify-center opacity-0 lg:col-span-7 lg:pl-16'
      >
        <div class='grid grid-cols-2 gap-8 md:grid-cols-3'>
          <div>
            <h3 class='mb-6 font-medium text-zinc-50'>Company</h3>
            <ul role='list' class='space-y-4'>
              {
                companyLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class='text-sm text-zinc-400 transition-colors hover:text-zinc-50'
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <h3 class='mb-6 font-medium text-zinc-50'>Resources</h3>
            <ul role='list' class='space-y-4'>
              {
                resourceLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class='text-sm text-zinc-400 transition-colors hover:text-zinc-50'
                    >
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <h3 class='mb-6 font-medium text-zinc-50'>Contact</h3>
            <ul role='list'>
              <li>
                <a
                  href='mailto:hello@growthapp.com'
                  class='text-sm text-zinc-400 transition-colors hover:text-zinc-50'
                >
                  hello@growthapp.com
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- social media -->
    <div
      class='footer-bottom flex flex-col items-start justify-between gap-6 pt-8 opacity-0 md:gap-12'
    >
      <div class='flex items-center gap-6'>
        <a href='#' class='text-zinc-400 transition-colors hover:text-zinc-50'>
          <span class='sr-only'>LinkedIn</span>
          <svg
            class='h-5 w-5'
            fill='currentColor'
            viewBox='-2 -2 24 24'
            xmlns='http://www.w3.org/2000/svg'
            preserveAspectRatio='xMinYMin'
            aria-hidden='true'
            ><path
              d='M19.959 11.719v7.379h-4.278v-6.885c0-1.73-.619-2.91-2.167-2.91-1.182 0-1.886.796-2.195 1.565-.113.275-.142.658-.142 1.043v7.187h-4.28s.058-11.66 0-12.869h4.28v1.824l-.028.042h.028v-.042c.568-.875 1.583-2.126 3.856-2.126 2.815 0 4.926 1.84 4.926 5.792zM2.421.026C.958.026 0 .986 0 2.249c0 1.235.93 2.224 2.365 2.224h.028c1.493 0 2.42-.989 2.42-2.224C4.787.986 3.887.026 2.422.026zM.254 19.098h4.278V6.229H.254v12.869z'
            ></path></svg
          >
        </a>
        <a href='#' class='text-zinc-400 transition-colors hover:text-zinc-50'>
          <span class='sr-only'>Twitter</span>
          <svg
            class='h-5 w-5'
            fill='currentColor'
            viewBox='0 0 24 24'
            aria-hidden='true'
            ><path
              d='M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84'
            ></path></svg
          >
        </a>
      </div>

      <!-- copyright -->
      <p class='text-xs text-zinc-500'>
        &copy; {new Date().getFullYear()} Growth. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  import { animate, inView } from 'motion';

  inView(
    '.footer-container',
    () => {
      animate(
        '.footer-brand',
        { opacity: [0, 1], y: [20, 0] },
        { duration: 0.8, ease: 'easeOut' },
      );

      animate(
        '.footer-nav',
        { opacity: [0, 1], y: [20, 0] },
        { duration: 0.8, delay: 0.4, ease: 'easeOut' },
      );

      animate(
        '.footer-bottom',
        { opacity: [0, 1], y: [20, 0] },
        { duration: 0.8, delay: 1, ease: 'easeOut' },
      );
    },
    { amount: 0.4 },
  );
</script>
