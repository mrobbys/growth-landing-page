---
import { Image } from 'astro:assets';
import Logo from '@assets/images/Logo.svg';
import NavLink from './NavLink.astro';
import Button from './ui/Button.astro';
---

<header
  x-data='{scrolled: false}'
  @scroll.window='scrolled = window.scrollY > 10'
  x-bind:class="scrolled ? 'shadow-xl' : 'shadow-none'"
  class='navbar-animate sticky top-0 z-50 w-full bg-zinc-50/70 backdrop-blur-md transition-all duration-500 ease-out pt-[env(safe-area-inset-top)]'
  style='transform: translateY(-100%);'
>
  <nav
    x-data='{ mobileMenuIsOpen: false }'
    x-on:click.away='mobileMenuIsOpen = false'
    class='mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 md:px-8'
    aria-label='penguin ui menu'
  >
    <!-- logo -->
    <a
      href='#'
      class='transition-transform duration-300 outline-none select-none hover:scale-105'
      draggable='false'
    >
      <Image src={Logo} alt='Brand Logo' loading='eager' draggable='false' />
    </a>
    <!-- desktop menu -->
    <ul class='hidden items-center gap-12 md:flex'>
      <li>
        <NavLink label='Features' variant='desktop' />
      </li>
      <li>
        <NavLink label='About Us' variant='desktop' />
      </li>
      <li>
        <NavLink label='Blog' variant='desktop' />
      </li>
      <li>
        <Button variant='secondary' size='sm'>Log in</Button>
      </li>
    </ul>
    <!-- mobile menu button -->
    <button
      x-on:click='mobileMenuIsOpen = !mobileMenuIsOpen'
      x-bind:aria-expanded='mobileMenuIsOpen'
      type='button'
      class='fixed top-4 right-6 z-20 flex text-zinc-600 md:hidden'
      aria-label='mobile menu'
      aria-controls='mobileMenu'
    >
      <svg
        x-cloak
        x-show='!mobileMenuIsOpen'
        xmlns='http://www.w3.org/2000/svg'
        fill='none'
        aria-hidden='true'
        viewBox='0 0 24 24'
        stroke-width='2'
        stroke='currentColor'
        class='size-10 rounded-xl bg-gray-100 p-2 text-zinc-950 shadow-md'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          d='M3.75 7.5h16.5M3.75 16.5h16.5'></path>
      </svg>
      <svg
        x-cloak
        x-show='mobileMenuIsOpen'
        xmlns='http://www.w3.org/2000/svg'
        fill='none'
        aria-hidden='true'
        viewBox='0 0 24 24'
        stroke-width='2'
        stroke='currentColor'
        class='size-10 rounded-xl bg-gray-100 p-2 text-zinc-950 shadow-md'
      >
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          d='M6 18 18 6M6 6l12 12'></path>
      </svg>
    </button>
    <!-- mobile menu -->
    <ul
      x-cloak
      x-show='mobileMenuIsOpen'
      x-transition:enter='transition motion-reduce:transition-none ease-out duration-300'
      x-transition:enter-start='-translate-y-full'
      x-transition:enter-end='translate-y-0'
      x-transition:leave='transition motion-reduce:transition-none ease-out duration-300'
      x-transition:leave-start='translate-y-0'
      x-transition:leave-end='-translate-y-full'
      id='mobileMenu'
      class='fixed inset-x-0 top-0 z-10 flex max-h-svh flex-col divide-y divide-zinc-300 overflow-y-auto rounded-b-sm bg-zinc-50 px-6 pt-20 pb-6 shadow-2xl md:hidden'
    >
      <li class='py-2'>
        <NavLink label='Features' variant='mobile' />
      </li>
      <li class='py-2'>
        <NavLink label='About Us' variant='mobile' />
      </li>
      <li class='py-2'>
        <NavLink label='Blog' variant='mobile' />
      </li>
      <li class='pt-4' x-on:click='mobileMenuIsOpen = !mobileMenuIsOpen'>
        <Button variant='secondary' size='sm' class='w-full'>Log in</Button>
      </li>
    </ul>
  </nav>
</header>

<script>
  import { animate } from 'motion';

  const navbar = document.querySelector('.navbar-animate');

  animate(navbar, { y: ['-100%', '0%'] }, { duration: 1.2, ease: 'easeOut' });
</script>
