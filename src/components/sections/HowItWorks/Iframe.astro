---
interface Props {
  videoId?: string;
  videoTitle?: string;
}

const {
  videoId = '-jokuknAtu8',
  videoTitle = 'How Growth Platform Works - Product Demo',
} = Astro.props;

const embedUrl = `https://www.youtube.com/embed/${videoId}?si=S0UVuoWWqm8uF5fP&modestbranding=1&rel=0`;
---

<div x-data='{ videoLoaded: false }' class='mx-auto w-full max-w-2xl'>
<!-- poster thumbnail -->
  <div
    x-show='!videoLoaded'
    x-transition
    class='relative aspect-video w-full overflow-hidden rounded-2xl bg-gray-200'
  >
    <img
      src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
      alt={videoTitle}
      loading='lazy'
      decoding='async'
      class='h-full w-full object-cover'
    />
  <!-- play btn overlay -->
    <button
      @click='videoLoaded = true'
      aria-label={`Play video: ${videoTitle}`}
      class='absolute inset-0 flex items-center justify-center bg-black/30 transition-all duration-300 hover:bg-black/50 focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:outline-none'
    >
      <svg
        xmlns='http://www.w3.org/2000/svg'
        viewBox='0 0 24 24'
        fill='black'
        class='h-12 w-12 cursor-pointer rounded-full bg-zinc-50 p-2 drop-shadow-lg md:h-16 md:w-16'
        aria-hidden='true'
      >
        <path d='M8 5v14l11-7z'></path>
      </svg>
    </button>
  </div>

  <iframe
    x-show='videoLoaded'
    x-transition.duration.300ms
    src={embedUrl}
    title={videoTitle}
    allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
    referrerpolicy='strict-origin-when-cross-origin'
    allowfullscreen
    loading='lazy'
    class='aspect-video w-full rounded-2xl'
    aria-label={videoTitle}></iframe>

  <!-- noscript fallback -->
  <noscript>
    <iframe
      src={embedUrl}
      title={videoTitle}
      allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
      referrerpolicy='strict-origin-when-cross-origin'
      allowfullscreen
      class='aspect-video w-full rounded-2xl'></iframe>
  </noscript>
</div>
