---
import PricingCard from './PricingCard.astro';
import pricingData from '@data/pricing.json';

// error handling
const pricingPlans =
  pricingData && Array.isArray(pricingData) ? pricingData : [];
---

<section id='pricing' aria-label='Pricing Plans and Features' class='relative'>
  <div class='mx-auto max-w-7xl space-y-10 px-4 py-16 md:px-8'>
    <header
      class='pricing-header space-y-4 text-center opacity-0 md:mx-auto md:w-2xl'
    >
      <h2 class='text-3xl font-medium'>Pricing</h2>
      <p>
        Start free and scale while you grow. No hidden fees. Unlimited users for
        free
      </p>
    </header>

    <div
      class='pricing-container flex flex-col items-center justify-center gap-4 md:flex-row'
      role='list'
    >
      {
        pricingPlans.length > 0 ? (
          pricingPlans.map((plan) => (
            <div role='listitem'>
              <PricingCard
                id={plan.id}
                variant={plan.variant as 'light' | 'dark'}
                title={plan.title}
                description={plan.description}
                price={plan.price}
                priceSuffix={plan.priceSuffix}
                preFeatureText={plan.preFeatureText}
                features={plan.features}
              />
            </div>
          ))
        ) : (
          <p class='py-8 text-zinc-500'>
            No pricing plans available at the moment.
          </p>
        )
      }
    </div>

    {
      pricingPlans.length > 0 && (
        <div class='pricing-footer space-y-4 text-center opacity-0'>
          <p>
            All prices are in USD and charger per month with applicable taxed
            added at checkout.
          </p>
          <a
            href='#'
            aria-label='View all features comparison'
            class='group inline-flex items-center justify-center gap-2 px-4 font-medium transition-colors duration-300 hover:text-blue-500'
          >
            <span>View features</span>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 52 52'
              enable-background='new 0 0 52 52'
              xml:space='preserve'
              class='h-6 w-6 text-zinc-900 transition-all duration-300 group-hover:-rotate-90 group-hover:text-blue-500'
              fill='currentColor'
              aria-hidden='true'
            >
              <path
                d='M9.6,31c-0.8,0.8-0.8,1.9,0,2.7l15,14.7c0.8,0.8,2,0.8,2.8,0l15.1-14.7c0.8-0.8,0.8-1.9,0-2.7l-2.8-2.7
	c-0.8-0.8-2-0.8-2.8,0l-4.7,4.6C31.4,33.7,30,33.2,30,32V5c0-1-0.9-2-2-2h-4c-1.1,0-2,1.1-2,2v27c0,1.2-1.4,1.7-2.2,0.9l-4.7-4.6
	c-0.8-0.8-2-0.8-2.8,0L9.6,31z'
              />
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  inView(
    '.pricing-header',
    (target) => {
      animate(
        target,
        { opacity: [0, 1], y: [40, 0] },
        { duration: 0.8, ease: 'easeOut' },
      );
    },
    { amount: 0.7 },
  );

  inView(
    '.pricing-container',
    (target) => {
      const cards = target.querySelectorAll('.pricing-card');

      if (cards[0]) {
        animate(
          cards[0],
          { opacity: [0, 1], x: [-100, 0] },
          { duration: 0.8, delay: 0.3, ease: 'easeOut' },
        );
      }

      if (cards[1]) {
        animate(
          cards[1],
          { opacity: [0, 1], x: [100, 0] },
          { duration: 0.8, delay: 0.6, ease: 'easeOut' },
        );
      }
    },
    { amount: 0.3 },
  );

  inView(
    '.pricing-footer',
    (target) => {
      animate(
        target,
        { opacity: [0, 1], y: [40, 0] },
        { duration: 0.8, delay: 0.5, ease: 'easeOut' },
      );
    },
  );
</script>
